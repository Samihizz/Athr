# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# design/source files (not needed in production)
*.pdf
/public/tracks/*.png
Athar PNG/
public/Track icons/
public/notifications-sql.sql
public/Screen Shot*

# typescript
*.tsbuildinfo
next-env.d.ts
public/tracks/*.svg
public/Track icons/

# claude skills (local tooling, not deployed)
.claude/skills/
